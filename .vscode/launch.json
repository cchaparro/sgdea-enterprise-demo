      "mainClass": "demo.App",
      "cwd": "${workspaceFolder}/gateway",
      "vmArgs": "-Dspring.profiles.active=local",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      }
    }
  ],
  "compounds": [
    {
      "name": "Debug Core Local Stack",
      "configurations": [
        "Debug Metadata Service",
        "Debug Search Service",
        "Debug Document Service"
      ]
    },
    {
      "name": "Debug All Local Services",
