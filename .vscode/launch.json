{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "Debug Identity Service",
      "request": "launch",
      "mainClass": "demo.App",
      "cwd": "${workspaceFolder}/identity-service",
      "vmArgs": "-Dspring.profiles.active=local",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      }
    },
    {
      "type": "java",
      "name": "Debug Document Service",
      "request": "launch",
      "mainClass": "demo.App",
      "cwd": "${workspaceFolder}/document-service",
