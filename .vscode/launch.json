      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      }
    },
    {
      "type": "java",
      "name": "Debug Metadata Service",
      "request": "launch",
      "mainClass": "demo.App",
      "cwd": "${workspaceFolder}/metadata-service",
      "vmArgs": "-Dspring.profiles.active=local",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local"
      }
    },
    {
      "type": "java",
      "name": "Debug Audit Service",
      "request": "launch",
      "mainClass": "demo.App",
      "cwd": "${workspaceFolder}/audit-service",
