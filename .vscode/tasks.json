{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Reset Infra",
      "type": "shell",
      "command": "docker compose down -v --remove-orphans && docker compose up -d postgres zookeeper kafka kafka-init minio elasticsearch kibana jaeger otel-collector kafka-ui",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Local Services Except Document",
      "type": "process",
      "command": "mvn",
      "args": [
        "spring-boot:run"
      ],
      "options": {
        "cwd": "${workspaceFolder}/identity-service",
        "env": {
          "SPRING_PROFILES_ACTIVE": "local"
        }
      },
      "dependsOrder": "parallel",
      "dependsOn": [
        "Run Identity Service Internal",
        "Run Metadata Service Internal",
        "Run Audit Service Internal",
        "Run Search Service Internal",
        "Run Gateway Internal"
      ],
      "problemMatcher": []
    },
    {
